-- Clean Charm ESP - Enemies Only (Team Check) - Keybind: DELETE

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

local ESP_ENABLED = false
local ESP_CACHE = {}

-- ================== CONFIG ==================
local TOGGLE_KEY = Enum.KeyCode.Delete

local ENEMY_COLOR = Color3.fromRGB(255, 85, 255)   -- Pink charm color
-- ============================================

local function createCharmHighlight(character)
    if not character or ESP_CACHE[character] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "CharmESP"
    highlight.Adornee = character
    highlight.FillColor = ENEMY_COLOR
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.6
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = character
    
    ESP_CACHE[character] = highlight
end

local function removeCharmHighlight(character)
    if ESP_CACHE[character] then
        ESP_CACHE[character]:Destroy()
        ESP_CACHE[character] = nil
    end
end

local function updateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            
            -- Team Check: Only show for enemies
            local isEnemy = (player.Team ~= LocalPlayer.Team) or (player.Team == nil)
            
            if humanoid and humanoid.Health > 0 and isEnemy then
                if ESP_ENABLED then
                    createCharmHighlight(character)
                else
                    removeCharmHighlight(character)
                end
            else
                removeCharmHighlight(character)
            end
        end
    end
end

-- Toggle with Delete key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == TOGGLE_KEY then
        ESP_ENABLED = not ESP_ENABLED
        print("Charm ESP:", ESP_ENABLED and "✅ ENABLED" or "❌ DISABLED")
        
        if not ESP_ENABLED then
            for _, highlight in pairs(ESP_CACHE) do
                highlight:Destroy()
            end
            ESP_CACHE = {}
        end
    end
end)

-- Main loop
RunService.RenderStepped:Connect(updateESP)

print("✅ Clean Charm ESP (Enemies Only) loaded!")
print("Press DELETE to toggle ON/OFF")
